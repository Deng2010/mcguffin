# CP OAuth 配置
# 复制此文件为 .env.local 并填入实际值

# CP OAuth 服务基础URL
VITE_CPOAUTH_BASE_URL=https://cpoauth.com

# 你的应用 Client ID (在 cpoauth.com/developer 注册获取)
VITE_CPOAUTH_CLIENT_ID=your-client-id-here

# 你的应用 Client Secret (仅用于后端代理，前端不推荐暴露)
# VITE_CPOAUTH_CLIENT_SECRET=your-client-secret-here

# 授权回调地址 (通常不需要修改)
# VITE_CPOAUTH_REDIRECT_URI=http://localhost:5173/oauth/cpoauth/callback